{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear",
        "hooks": [
          {
            "type": "command",
            "command": "[ -s .claude/lessons.md ] && cat .claude/lessons.md || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | tr '\\n' '\\0' | xargs -0 npx prettier --write -- 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | tr '\\n' '\\0' | xargs -0 npx eslint --fix -- 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
